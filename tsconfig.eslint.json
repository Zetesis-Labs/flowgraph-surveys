{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "composite": false,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": [
    ".dependency-cruiser.cjs",
    "*.js",
    "*.cjs",
    "scripts/**/*.mjs",
    "test/**/*.mjs",
    "test/**/*.ts",
    "test/**/*.tsx",
    "*.ts",
    "apps/*/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/test/**/*.ts",
    "apps/*/test/**/*.tsx"
  ]
}
