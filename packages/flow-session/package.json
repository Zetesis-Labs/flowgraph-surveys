{
  "name": "@flowgraph/session",
  "version": "0.1.0",
  "description": "Observable single-writer shell for @flowgraph/core",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck:prod": "tsc -p tsconfig.json --noEmit",
    "clean": "tsc -b --clean",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --project session"
  },
  "dependencies": {
    "@flowgraph/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
