{
  "name": "@flowgraph/react",
  "version": "0.1.0",
  "description": "React bindings and accessible survey renderers for FlowGraph",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck:prod": "tsc -p tsconfig.json --noEmit",
    "clean": "tsc -b --clean",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --project react"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "@flowgraph/core": "workspace:*",
    "@flowgraph/session": "workspace:*"
  }
}
