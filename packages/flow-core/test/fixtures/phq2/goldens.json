      "commands": [
        { "kind": "START" },
        { "kind": "ANSWER", "q": "q1", "value": ["sometimes"] },
        { "kind": "ANSWER", "q": "q2", "value": ["sometimes"] },
        { "kind": "NEXT" }
      ],
      "expect": { "outcome": "negative", "state": { "current": "negative" } }
