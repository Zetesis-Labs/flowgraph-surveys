{
  "name": "flowgraph",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false && pnpm -r typecheck:test",
    "boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test -c test/browser/playwright.config.ts",
    "test:demo-browser": "playwright test -c test/demo-browser/playwright.config.ts",
    "demo": "pnpm --filter @flowgraph/survey-demo dev",
    "demo:build": "pnpm --filter @flowgraph/survey-demo build",
    "build": "tsc -b --pretty false",
    "package:check": "node scripts/package-check.mjs",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@flowgraph/core": "workspace:*",
    "@flowgraph/react": "workspace:*",
    "@flowgraph/session": "workspace:*",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
